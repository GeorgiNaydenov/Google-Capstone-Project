<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="Deployment Topology">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" page="1" pageWidth="1420" pageHeight="820">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Deployment Topology, Nexus Clinical AI Command Center" style="text;html=1;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="360" y="10" width="700" height="30" as="geometry" />
        </mxCell>
        <mxCell id="dev" value="Developer&#xa;runs gcloud builds submit&#xa;with deployment/cloudbuild.yaml" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="230" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="cb" value="Cloud Build pipeline" style="swimlane;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;html=1;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="80" width="340" height="360" as="geometry" />
        </mxCell>
        <mxCell id="s1" value="Step 1&#xa;builds the Docker image from deployment/Dockerfile" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="cb">
          <mxGeometry x="30" y="50" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="Step 2&#xa;pushes the image to the Container Registry" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="cb">
          <mxGeometry x="30" y="160" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="Step 3&#xa;deploys the service with gcloud run deploy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="cb">
          <mxGeometry x="30" y="270" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="reg" value="Container Registry&#xa;gcr.io image&#xa;clinical-ai-command-center" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;boundedLbl=1;" vertex="1" parent="1">
          <mxGeometry x="740" y="90" width="220" height="100" as="geometry" />
        </mxCell>
        <mxCell id="run" value="Cloud Run service&#xa;us-central1, port 8080, 1 Gi memory, max 1 instance&#xa;AGENT_EXECUTION_MODE=live, HIPAA_MODE=TRUE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="320" width="260" height="120" as="geometry" />
        </mxCell>
        <mxCell id="vertex" value="Vertex AI global endpoint&#xa;Gemini 3.1 through Application Default Credentials&#xa;runtime service account holds roles/aiplatform.user" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="1120" y="320" width="260" height="120" as="geometry" />
        </mxCell>
        <mxCell id="secret" value="Secret Manager (optional)&#xa;stores GOOGLE_API_KEY when Vertex credentials are not used" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1120" y="100" width="260" height="90" as="geometry" />
        </mxCell>
        <mxCell id="alt" value="Alternative deployment targets" style="swimlane;startSize=30;fillColor=#fff2cc;strokeColor=#d6b656;html=1;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="560" width="680" height="180" as="geometry" />
        </mxCell>
        <mxCell id="ae" value="Vertex AI Agent Engine&#xa;adk deploy agent_engine with&#xa;deployment/.agent_engine_config.json" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;" vertex="1" parent="alt">
          <mxGeometry x="30" y="50" width="300" height="100" as="geometry" />
        </mxCell>
        <mxCell id="gke" value="Google Kubernetes Engine&#xa;containerized deployment&#xa;for cluster operators" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;" vertex="1" parent="alt">
          <mxGeometry x="360" y="50" width="290" height="100" as="geometry" />
        </mxCell>
        <mxCell id="clin" value="Clinician" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="1140" y="580" width="50" height="80" as="geometry" />
