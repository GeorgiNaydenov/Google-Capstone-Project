# Secrets — never bake credentials into the image
.env
.env.*
.env.local
*.env.local

# Version control and tooling state
.git
.gitignore
.claude
.agents
.codex
.mypy_cache
.pytest_cache
.coverage
htmlcov
.run-logs
.run-venv
.venv-codex
.uv-cache
.ruff_cache
.tmp
.tmp_showcase_validation
.docker-tmp
tmp_*

# Python and Node build artifacts
__pycache__
*.pyc
*.tsbuildinfo
.venv
venv
node_modules
frontend/node_modules
frontend/dist

# Tenant data must never be copied into the image — the real tenant's
# database and uploads live on a mounted volume at runtime.
*.db
*.db-wal
*.db-shm
uploads
uploads_*
!showcase_data/**

# Docs source trees (the built hub ships inside frontend/dist)
Project Wiki
wiki
raw
docs
docs_site
deployment/cloudbuild.yaml
