# =============================================================================
# Google Capstone Project — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   copy .env.example .env
#
# NEVER commit .env to version control.
# =============================================================================

# --- Gemini API (Option 1: Direct API key) ---
GOOGLE_API_KEY=your-gemini-api-key-here
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# --- Vertex AI (Option 2: Google Cloud project) ---
# Set GOOGLE_GENAI_USE_VERTEXAI=TRUE and the values below to route through
# Vertex AI (required for VertexAiMemoryBankService and Agent Engine deploy).
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# --- Model Selection (see capstone_agent/llm.py) ---
# MODEL_TIER picks the default tier; MODEL_ID overrides the concrete model for
# that default tier. Per-agent overrides happen in code via build_model(tier=).
#   flash-lite      -> gemini-3.1-flash-lite              (default: cheap/fast)
#   pro             -> gemini-3.1-pro-preview             (frontier reasoning)
#   pro-customtools -> gemini-3.1-pro-preview-customtools (best function calling)
MODEL_TIER=flash-lite
MODEL_ID=gemini-3.1-flash-lite

# --- Application Settings ---
APP_NAME=capstone_agent
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Observability (Day 4a) ---
ENABLE_TRACING=FALSE
# Where OpenTelemetry spans go when tracing is enabled: otlp | gcp (Cloud Trace)
TRACE_EXPORTER=otlp

# --- Memory backends (Day 3a / 3b) ---
# SESSION_BACKEND: memory (dev) | database (persistent, needs google-adk[db])
SESSION_BACKEND=memory
SESSION_DB_URL=sqlite+aiosqlite:///./capstone_sessions.db
# MEMORY_BACKEND: memory (dev) | vertex (VertexAiMemoryBankService, needs Vertex)
MEMORY_BACKEND=memory
# AGENT_ENGINE_ID=projects/.../locations/.../reasoningEngines/...

# --- Long-running ops / Human-in-the-loop (Day 2b) ---
ENABLE_RESUMABILITY=TRUE

# --- Agent2Agent serving (Day 5a) ---
A2A_PORT=8001

# --- Context Engineering ---
MAX_TOOL_COUNT=15
SESSION_COMPACT_AFTER=40

# --- Clinical Governance ---
# HIPAA mode enforces PHI redaction and audit logging for all patient-data
# access paths. When TRUE, PHI_REDACTION is forced on regardless of its value.
HIPAA_MODE=TRUE
PHI_REDACTION=TRUE
# HIPAA requires 6-year retention of access logs (45 CFR 164.530(j)).
AUDIT_RETENTION_DAYS=2190
# Extraction outputs below this confidence threshold require clinician review.
EXTRACTION_CONFIDENCE_THRESHOLD=0.80
# When TRUE, all extraction persistence is gated behind HITL approval.
SENSITIVE_APPROVAL=TRUE
